
#<!DOCTYPE html>
<html>
<head>
<title>HTML Links Example</title>
</head>
<body>
<h1>Links in HTML</h1>
<!-- Text Link -->
<p>
Click here to visit
<a href="https://www.aec.edu.in/">AEC Website</a>
</p>
<!-- Open link in a new tab -->
<p>
Click here to open AEC Website in new tab
<a href="https:www.aec.edu.in/"target="_blank">Open AEC</a>
</p>
<hr>
<!-- Image as a link -->
<h2>Click the Image to open AEC Gallery</h2>
<a href="https://adityauniversity.in/images/gallery/7.webp" target="_blank">
<img scr="https;//via.placeholder.com/250*120?text=AEC+Gallery" alt="AEC Aallery Image">
</a>
</body>
</html>
